<html>
  <head>
      <title>Form</title>
  </head>
  <body>

    <div class="container">

        <h3>Form</h3> 

        <form method="POST" action="/new">
          <label>
            Message Text:
            <input type="text" name="messageText">
          </label>
          <label>
            Author Name:
            <input type="text" name="messageUser">
          </label>
            <button type="submit">Submit</button>
        </form>
      
    </div>

  </body>
</html>